END

sub create-pdf($markdown_file, $output_path) {

    die if not $markdown_file.IO.e;

    if not $output_path.IO.e {

        #--variable mathfont=\"/Users/kleb/Library/Fonts/STIXTwoMath-Regular.otf\" 
        #--template=custom-template.latex
        my $cmd = qq:to/END/.split("\n").join(" ");
        pandoc 
        --pdf-engine=xelatex 
        --include-in-header=preamble.tex
        -V geometry:margin=0.7in $markdown_file -o $output_path
        END

        say "processing: $output_path";

        shell($cmd);
    }
}

create-pdf("caffe-doc.md", "caffe2-doc.pdf");

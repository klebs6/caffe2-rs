("caffe2-aten-test/src/test_xnnpack_test.rs",                      "caffe2-aten-xnnpack"),

];
           
my @commands;

for @pairs -> ($src, $crate) {

    die "$src does not exist!" if !$src.IO.e;

    my $basename   = $src.IO.basename;
    my $target-dir = $crate ~ "/src";

    if !$target-dir.IO.e {
        qqx/mkdir $target-dir/;
    }

    my $target     = $target-dir ~ "/$basename";

    if $target.IO.e {

        my $new-target = $target.split(".")[0] ~ "_cuda.rs";

        say "$target already exists!! will rename to $new-target";

        die "$new-target already exists!!! will not overwrite" if $new-target.IO.e;

        $target = $new-target;
    }

    my $command = "mv $src $target";

    @commands.push: $command;
}

my @crates = @pairs.map({ $_[1] }).sort.unique;
my $create = "./u/create-workspace-crate";

for @crates -> $crate {

    if !$crate.IO.e {
        my $command = "$create $crate";
        @commands.push: $command;
    }
}

sub MAIN(Bool :$write = False) {

    for @commands -> $command {

        say $command;

        if $write {
            my $output = qqx/$command/;
            say $output.chomp;
        }
    }
}
